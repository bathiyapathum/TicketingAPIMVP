{
  "openapi": "3.0.1",
  "info": {
    "title": "Flight Booking API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Paths are resolved relative to your API host (Foundry connection base URL)."
    }
  ],
  "paths": {
    "/api/flights": {
      "get": {
        "tags": [
          "Flights"
        ],
        "summary": "Get all flights with optional route/date filtering.",
        "operationId": "flights_get_all",
        "parameters": [
          {
            "name": "origin",
            "in": "query",
            "description": "Origin city.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "destination",
            "in": "query",
            "description": "Destination city.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Departure date (yyyy-MM-dd).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FlightListItemDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/flights/{id}": {
      "get": {
        "tags": [
          "Flights"
        ],
        "summary": "Get flight details by ID.",
        "operationId": "flights_get_by_id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Flight identifier.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightDetailsDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/flights/search": {
      "get": {
        "tags": [
          "Flights"
        ],
        "summary": "Search flights for AI agent usage.",
        "operationId": "flights_search",
        "parameters": [
          {
            "name": "origin",
            "in": "query",
            "description": "Origin city.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "destination",
            "in": "query",
            "description": "Destination city.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "Departure date (yyyy-MM-dd).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FlightListItemDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/reports/revenue": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Get total revenue grouped by route and flight.",
        "operationId": "reports_revenue",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RevenueReportDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/reports/bookings-by-route": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Get booking count per route.",
        "operationId": "reports_bookings_by_route",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BookingsByRouteDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/reports/seat-occupancy": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Get seat occupancy percentage for a flight.",
        "operationId": "reports_seat_occupancy",
        "parameters": [
          {
            "name": "flightId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SeatOccupancyDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/reports/daily-bookings": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Get daily booking trend.",
        "operationId": "reports_daily_bookings",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DailyBookingTrendDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/reports/agent-summary": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Get high-level summary for AI agents.",
        "operationId": "reports_agent_summary",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentSummaryDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/reservations": {
      "post": {
        "tags": [
          "Reservations"
        ],
        "summary": "Create a new reservation.",
        "operationId": "reservations_create",
        "requestBody": {
          "description": "Booking payload.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReservationRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservationDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/reservations/{id}": {
      "get": {
        "tags": [
          "Reservations"
        ],
        "summary": "Get reservation details by ID.",
        "operationId": "reservations_get_by_id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Reservation identifier.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservationDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Reservations"
        ],
        "summary": "Cancel reservation and release the seat.",
        "operationId": "reservations_cancel",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Reservation identifier.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/flights/{flightId}/seats": {
      "get": {
        "tags": [
          "Seats"
        ],
        "summary": "Get seat matrix for the selected flight.",
        "operationId": "seats_get_by_flight",
        "parameters": [
          {
            "name": "flightId",
            "in": "path",
            "description": "Flight identifier.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SeatStatusDto"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AgentSummaryDto": {
        "type": "object",
        "properties": {
          "totalFlights": {
            "type": "integer",
            "format": "int32"
          },
          "totalBookings": {
            "type": "integer",
            "format": "int32"
          },
          "totalRevenue": {
            "type": "number",
            "format": "double"
          },
          "occupancyRate": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "BookingsByRouteDto": {
        "type": "object",
        "properties": {
          "route": {
            "type": "string",
            "nullable": true
          },
          "bookingCount": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "CreateReservationRequestDto": {
        "required": [
          "email",
          "flightId",
          "passengerName",
          "passportNo",
          "seatNumber"
        ],
        "type": "object",
        "properties": {
          "flightId": {
            "type": "integer",
            "format": "int32"
          },
          "passengerName": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "passportNo": {
            "maxLength": 30,
            "minLength": 1,
            "type": "string"
          },
          "seatNumber": {
            "minLength": 1,
            "pattern": "^[1-2][A-D]$",
            "type": "string"
          }
        }
      },
      "DailyBookingTrendDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "bookingCount": {
            "type": "integer",
            "format": "int32"
          },
          "revenue": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "FlightDetailsDto": {
        "type": "object",
        "properties": {
          "flightId": {
            "type": "integer",
            "format": "int32"
          },
          "flightCode": {
            "type": "string",
            "nullable": true
          },
          "origin": {
            "type": "string",
            "nullable": true
          },
          "destination": {
            "type": "string",
            "nullable": true
          },
          "departureTime": {
            "type": "string",
            "format": "date-time"
          },
          "arrivalTime": {
            "type": "string",
            "format": "date-time"
          },
          "durationMinutes": {
            "type": "integer",
            "format": "int32"
          },
          "basePrice": {
            "type": "number",
            "format": "double"
          },
          "aircraftName": {
            "type": "string",
            "nullable": true
          },
          "totalSeats": {
            "type": "integer",
            "format": "int32"
          },
          "reservedSeats": {
            "type": "integer",
            "format": "int32"
          },
          "availableSeats": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "FlightListItemDto": {
        "type": "object",
        "properties": {
          "flightId": {
            "type": "integer",
            "format": "int32"
          },
          "flightCode": {
            "type": "string",
            "nullable": true
          },
          "origin": {
            "type": "string",
            "nullable": true
          },
          "destination": {
            "type": "string",
            "nullable": true
          },
          "departureTime": {
            "type": "string",
            "format": "date-time"
          },
          "arrivalTime": {
            "type": "string",
            "format": "date-time"
          },
          "durationMinutes": {
            "type": "integer",
            "format": "int32"
          },
          "basePrice": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "MessageResponseDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ReservationDto": {
        "type": "object",
        "properties": {
          "reservationId": {
            "type": "integer",
            "format": "int32"
          },
          "flightId": {
            "type": "integer",
            "format": "int32"
          },
          "flightCode": {
            "type": "string",
            "nullable": true
          },
          "passengerName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "passportNo": {
            "type": "string",
            "nullable": true
          },
          "seatNumber": {
            "type": "string",
            "nullable": true
          },
          "totalAmount": {
            "type": "number",
            "format": "double"
          },
          "bookingStatus": {
            "type": "string",
            "nullable": true
          },
          "bookingDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RevenueReportDto": {
        "type": "object",
        "properties": {
          "route": {
            "type": "string",
            "nullable": true
          },
          "flightCode": {
            "type": "string",
            "nullable": true
          },
          "totalBookings": {
            "type": "integer",
            "format": "int32"
          },
          "totalRevenue": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "SeatOccupancyDto": {
        "type": "object",
        "properties": {
          "flightId": {
            "type": "integer",
            "format": "int32"
          },
          "flightCode": {
            "type": "string",
            "nullable": true
          },
          "totalSeats": {
            "type": "integer",
            "format": "int32"
          },
          "reservedSeats": {
            "type": "integer",
            "format": "int32"
          },
          "occupancyRate": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "SeatStatusDto": {
        "type": "object",
        "properties": {
          "seatNumber": {
            "type": "string",
            "nullable": true
          },
          "isReserved": {
            "type": "boolean"
          },
          "rowNumber": {
            "type": "integer",
            "format": "int32"
          },
          "columnLetter": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  }
}